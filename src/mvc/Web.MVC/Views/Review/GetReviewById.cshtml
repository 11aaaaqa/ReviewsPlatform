    <input class="hidden" id="commentTextMaxLength" value="@StringLengthDtoConstants.CommentTextMax" />
    <input class="hidden" id="reviewId" value="@Model.Review.Id" />
    <form style="margin-top: 20px;" id="addCommentForm" class="add-comment-form" data-parent-id="">
        <div id="commentErrorMessageContainer" class="comment-error" style="display: none; color: red; margin-bottom: 3px;"></div>
        <div class="add-comment-block" contenteditable="true" data-placeholder="Введите комментарий"></div>
        <button type="submit" class="btn">Отправить</button>
    </form>
    
    <div class="comments-block">
        <h4>Комментарии: @Model.Review.CommentsCount</h4>

        <div id="rootCommentsContainer" class="comments-list"
             data-page-number="0"
             data-has-next="true">
        </div>

        <div id="getCommentsSentinel" style="height: 10px;"></div>
        <div id="loadSpinnerContainer" class="load-spinner-container hidden">
            <div class="load-spinner"></div>
        </div>
        <div id="rootLoadErrorMessageContainer" style="display: none; color: red; margin-bottom: 3px;"></div>
    </div>
    
    <template id="commentNodeTemplate">
        <div class="comment-block">
            <div class="comment-header">
                <img class="comment-avatar" src="" style="width: 30px; height: 30px; object-fit: cover;" />
                <p class="comment-username"></p>
                <p class="comment-date"></p>
            </div>
            <div class="comment-text"></div>
            <div class="comment-actions">
                <button type="button" class="btn-link reply-toggle-btn">Ответить</button>
                <button type="button" class="btn-link replies-toggle-btn hidden">
                    <span class="replies-toggle-label"></span>
                </button>
            </div>

            <form class="add-comment-form reply-form hidden" data-parent-id="">
                <div class="comment-error" style="display: none; color: red; margin-bottom: 3px;"></div>
                <div class="add-comment-block" contenteditable="true" data-placeholder="Введите комментарий"></div>
                <button type="submit" class="btn">Ответить</button>
                <button type="button" class="btn-red reply-cancel-btn">Отмена</button>
            </form>

            <div class="replies-container hidden"
                 data-page-number="0"
                 data-has-next="false"
                 data-loaded="false"></div>

            <button type="button" class="btn-link load-more-replies-btn hidden">Показать ещё ответы</button>
            <div class="load-spinner-container replies-loader hidden">
                <div class="load-spinner"></div>
            </div>
        </div>
    </template>
</div>

<script>
    const commentTextMaxLength = parseInt(document.getElementById('commentTextMaxLength').value, 10);
    const reviewId = document.getElementById('reviewId').value;
    const rootPageSize = 30;

    const REPLY_MAX_INDENT_LEVEL = 3;
    const REPLY_REPLIES_PAGE_SIZE = 10;

    const rootContainer = document.getElementById('rootCommentsContainer');
    const rootLoader = document.getElementById('loadSpinnerContainer');
    const rootLoadErrorMessageContainer = document.getElementById('rootLoadErrorMessageContainer');
    const commentNodeTemplate = document.getElementById('commentNodeTemplate');

    function formatDate(isoString) {
        const date = new Date(isoString);
        const datePart = date.toLocaleDateString();
        const hours = date.getHours().toString().padStart(2, '0');
        const minutes = date.getMinutes().toString().padStart(2, '0');
        return `${datePart} в ${hours}:${minutes}`;
    }

    function attachInputLimiters(editableDiv) {
        editableDiv.addEventListener('beforeinput', function (e) {
            const currentLength = editableDiv.innerHTML.length;
            const selectedTextLength = window.getSelection().toString().length;
            if (currentLength - selectedTextLength >= commentTextMaxLength && e.inputType.startsWith('insert')) {
                e.preventDefault();
            }
        });

        editableDiv.addEventListener('paste', function (e) {
            const paste = (e.clipboardData || window.clipboardData).getData('text');
            const currentLength = editableDiv.innerHTML.length;
            const selection = window.getSelection().toString().length;
            if (currentLength - selection + paste.length > commentTextMaxLength) {
                e.preventDefault();
                const allowedLength = commentTextMaxLength - (currentLength - selection);
                if (allowedLength > 0) {
                    document.execCommand('insertText', false, paste.substring(0, allowedLength));
                }
            }
        });
    }

    function attachFormSubmit(form) {
        const editableDiv = form.querySelector('.add-comment-block');
        attachInputLimiters(editableDiv);
        const errorContainer = form.querySelector('.comment-error');
        form.addEventListener('submit', async function (e) {
            e.preventDefault();

            const submitBtn = form.querySelector('[type="submit"]');
            if (submitBtn.disabled) return;

            submitBtn.disabled = true;

            const text = editableDiv.innerHTML.trim();
            errorContainer.textContent = '';
            errorContainer.style.display = 'none';

            if (!text) {
                errorContainer.textContent = 'Комментарий не может быть пустым';
                errorContainer.style.display = 'block';
                submitBtn.disabled = false;
                return;
            }
            try {
                const parentCommentId = form.dataset.parentId || null;
                const payload = {
                    text: text,
                    reviewId: reviewId,
                    parentCommentId: parentCommentId
                };

                const response = await fetch('/comments/add', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });


                if (response.redirected)
                {
                    window.location.href = response.url;
                } else if (response.status === 400)
                {
                    const result = await response.json();

                    errorContainer.textContent = '';

                    if (result.errors && result.errors.length > 0)
                    {
                        result.errors.forEach(error => {
                            const errorItem = document.createElement('div');
                            errorItem.textContent = error;
                            errorContainer.appendChild(errorItem);
                        });
                        errorContainer.style.display = 'block';
                    }
                } else
                {
                    errorContainer.textContent = 'Что-то пошло не так';
                    errorContainer.style.display = 'block';
                }
            } catch (err) {
                errorContainer.textContent = 'Что-то пошло не так';
                errorContainer.style.display = 'block';
            } finally {
                submitBtn.disabled = false;
            }
        });
    }

    attachFormSubmit(document.getElementById('addCommentForm'));

    function createCommentNode(comment, level) {
        const fragment = commentNodeTemplate.content.cloneNode(true);
        const block = fragment.querySelector('.comment-block');

        block.dataset.commentId = comment.id;
        block.dataset.level = level;

        const indentLevel = Math.min(level, REPLY_MAX_INDENT_LEVEL);
        if (indentLevel > 0) {
            block.style.marginLeft = (indentLevel * 24) + 'px';
        }

        const avatar = block.querySelector('.comment-avatar');
        avatar.src = comment.user.avatarSrc;

        block.querySelector('.comment-username').textContent = comment.user.userName;
        block.querySelector('.comment-date').textContent = formatDate(comment.createdAt);
        block.querySelector('.comment-text').innerHTML = comment.text;

        const replyForm = block.querySelector('.reply-form');
        replyForm.dataset.parentId = comment.id;
        attachFormSubmit(replyForm);

        const replyToggleBtn = block.querySelector('.reply-toggle-btn');
        const replyCancelBtn = block.querySelector('.reply-cancel-btn');
        replyToggleBtn.addEventListener('click', function () {
            replyForm.classList.toggle('hidden');
            if (!replyForm.classList.contains('hidden')) {
                replyForm.querySelector('.add-comment-block').focus();
            }
        });
        replyCancelBtn.addEventListener('click', function () {
            replyForm.classList.add('hidden');
        });

        const repliesToggleBtn = block.querySelector('.replies-toggle-btn');
        const repliesToggleLabel = block.querySelector('.replies-toggle-label');
        const repliesContainer = block.querySelector('.replies-container');
        const loadMoreRepliesBtn = block.querySelector('.load-more-replies-btn');
        const repliesLoader = block.querySelector('.replies-loader');

        if (comment.repliesCount > 0) {
            repliesToggleBtn.classList.remove('hidden');
            repliesToggleLabel.textContent = `Показать ответы (${comment.repliesCount})`;

            let repliesOpen = false;
            repliesToggleBtn.addEventListener('click', async function () {
                repliesOpen = !repliesOpen;
                if (repliesOpen) {
                    repliesToggleLabel.textContent = 'Скрыть ответы';
                    repliesContainer.classList.remove('hidden');
                    if (repliesContainer.dataset.loaded !== 'true') {
                        await loadReplies(repliesContainer, loadMoreRepliesBtn, repliesLoader, comment.id, level + 1, true);
                        repliesContainer.dataset.loaded = 'true';
                    }
                } else {
                    repliesToggleLabel.textContent = `Показать ответы (${comment.repliesCount})`;
                    repliesContainer.classList.add('hidden');
                    loadMoreRepliesBtn.classList.add('hidden');
                }
            });
        }

        loadMoreRepliesBtn.addEventListener('click', function () {
            loadReplies(repliesContainer, loadMoreRepliesBtn, repliesLoader, comment.id, level + 1, false);
        });

        return block;
    }

    async function loadReplies(container, loadMoreBtn, loader, commentId, level, isFirstLoad) {
        const pageSize = REPLY_REPLIES_PAGE_SIZE;
        const nextPageNumber = isFirstLoad ? 1 : (parseInt(container.dataset.pageNumber, 10) || 0) + 1;

        loadMoreBtn.disabled = true;
        loader.classList.remove('hidden');

        try {
            const url = `/comments/${commentId}/replies?pageSize=${pageSize}&pageNumber=${nextPageNumber}`;
            const response = await fetch(url);
            const result = await response.json();

            result.comments.forEach(function (reply) {
                const node = createCommentNode(reply, level);
                container.appendChild(node);
            });

            container.dataset.pageNumber = nextPageNumber;
            container.dataset.hasNext = result.isNextPageExisted ? 'true' : 'false';
            loadMoreBtn.classList.toggle('hidden', !result.isNextPageExisted);
        } catch (err) {
            loader.textContent = 'Не удалось загрузить ответы';
        } finally {
            loadMoreBtn.disabled = false;
            loader.classList.add('hidden');
            loader.innerHTML = '<div class="load-spinner"></div>';
        }
    }

    let rootLoadInProgress = false;

    function hasMoreRootComments() {
        return rootContainer.dataset.hasNext === 'true';
    }

    async function loadRootComments(pageNumber) {
        if (rootLoadInProgress) return;
        rootLoadInProgress = true;
        rootLoader.classList.remove('hidden');
        rootLoadErrorMessageContainer.style.display = 'none';

        try {
            const url = `/reviews/${reviewId}/comments?pageSize=${rootPageSize}&pageNumber=${pageNumber}`;
            const response = await fetch(url);
            const result = await response.json();

            result.comments.forEach(function (comment) {
                const node = createCommentNode(comment, 0);
                rootContainer.appendChild(node);
            });

            rootContainer.dataset.pageNumber = pageNumber;
            rootContainer.dataset.hasNext = result.isNextPageExisted ? 'true' : 'false';
        } catch (err) {
            rootLoadErrorMessageContainer.textContent = 'Не удалось загрузить комментарии';
            rootLoadErrorMessageContainer.style.display = 'block';
        } finally {
            rootLoadInProgress = false;
            rootLoader.classList.add('hidden');
            rootLoadErrorMessageContainer.style.display = 'none';
        }
    }

    const sentinel = document.getElementById('getCommentsSentinel');
    const observer = new IntersectionObserver((entries) => {
        if (entries[0].isIntersecting && hasMoreRootComments() && !rootLoadInProgress) {
            const nextPage = parseInt(rootContainer.dataset.pageNumber, 10) + 1;
            loadRootComments(nextPage);
        }
    }, {
        rootMargin: '100px'
    });
    observer.observe(sentinel);

    loadRootComments(1);







